prune __MACOSX
prune .sdist-audit
prune .sdist-check
prune .venv
prune .pytest_cache
prune .ruff_cache
prune .snakemake
prune benchmarks/known_motif_panel/runs
prune real_db
prune real_db_sources
prune real_run_realdb
